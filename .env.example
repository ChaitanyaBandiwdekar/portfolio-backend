# Gemini API key (langchain-google-genai). Never GEMINI_API_KEY.
GOOGLE_API_KEY=
GEMINI_CHAT_MODEL=gemini-flash-lite-latest

# Supabase project
SUPABASE_URL=
SUPABASE_SERVICE_KEY=

# Comma-separated exact origins allowed to call the API
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://chaitanyab.netlify.app

# LangSmith tracing (optional; app runs fine with these unset)
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=

# development | production
ENV=development

# Worst-case Gemini calls/day budget: turns * up to 5 calls/turn
GLOBAL_DAILY_CAP=50
